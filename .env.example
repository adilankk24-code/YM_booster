# ── Stripe keys (เอามาจาก Stripe Dashboard → Developers → API keys) ──
# ⚠️ ห้าม commit ไฟล์นี้ขึ้น git — ใส่ค่าจริงในไฟล์ .env เท่านั้น
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxx

# Webhook signing secret (จาก Stripe Dashboard → Developers → Webhooks → เลือก endpoint)
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx

# ── ความลับสำหรับเซ็น JWT (สุ่มยาว ๆ เช่น: openssl rand -hex 32) ──
JWT_SECRET=เปลี่ยนเป็นค่าสุ่มยาวก่อนขึ้น-production

# ── อีเมล (ลืมรหัสผ่าน) ── ไม่ตั้งก็ได้ → โหมด dev พิมพ์ลิงก์ออก console
# ผู้ให้บริการที่ตั้งง่าย: Resend / Brevo / Mailgun / Gmail SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=BoostHub <no-reply@boosthub.local>

# URL หน้าเว็บลูกค้า (ใช้ประกอบลิงก์รีเซ็ต → <FRONTEND_URL>/reset-password?token=...)
FRONTEND_URL=http://localhost:3000

# ── บัญชีแอดมินตัวแรก (ใช้ตอนรัน npm run seed) ──
ADMIN_EMAIL=admin@boosthub.local
ADMIN_PASSWORD=admin1234

# ที่เก็บไฟล์ฐานข้อมูล SQLite (ไม่ตั้งก็ได้ → boosthub.db)
DB_PATH=./boosthub.db

# พอร์ตของเซิร์ฟเวอร์
PORT=4242

# โดเมนหน้าเว็บ (สำหรับ CORS) เช่น https://boosthub.example.com
FRONTEND_ORIGIN=*
